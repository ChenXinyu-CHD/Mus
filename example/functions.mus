extern printf: fn(&i8, ...):i32

fn foo(a: i32, b: i32): i32
{
    return a
}

fn bar(a: i32, b: i32): i32
{
    return b
}

fn main(): i32
{
    var v1 = foo(69, 420);
    var v2 = bar(69, 420);
    printf("v1 = %d, v2 = %d\n", v1, v2);
    printf("foo(v1, v2) = %d, bar(v1, v2) = %d\n", foo(v1, v2), bar(v1, v2));
    return 0;
}
