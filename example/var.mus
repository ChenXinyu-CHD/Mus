# extern printf: fn(&i8, ...):i64

let main = fn() -> i64
{
  # var v1 # this is not allowed currently, because its type is not provided
  var v2: i32
  var v3 = 1

  printf("v2 = %ld, v3 = %ld\n", v2, v3);

  v2 = v3
  v3 = v2 + v3
  printf("v2 = %ld, v3 = %ld\n", v2, v3);

  return 0
}

let printf = fn(&i8, ...) -> i64 @extern

