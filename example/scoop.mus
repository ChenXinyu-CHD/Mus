let main = fn() -> i32
{
    let bar = fn() -> i32 {
        return 114514;
    }
    let foo = fn() -> i32 {
        return bar();
    }
    var a = foo();
    {
        printf("a = %d\n", a);
        var a =
            a + 1;
        var foo = 38324;
        printf("a = %d, foo = %ld\n", a, foo);
    }
    printf("a = %d\n", a);
    return 0;
}

let printf = fn(fmt: &i8, ...) -> i32 @extern;

