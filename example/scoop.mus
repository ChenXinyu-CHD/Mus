fn main(): i32
{
    fn bar():i32 {
        return 114514;
    }
    fn foo():i32 {
        return bar();
    }
    var a = foo();
    {
        printf("a = %d\n", a);
        var a =
            a + 1;
        var foo = 38324;
        printf("a = %d, foo = %ld\n", a, foo);
    }
    printf("a = %d\n", a);
    return 0;
}

extern printf: fn(&i8, ...):i32;

